// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  LICENCE
  MASTER
  ENGINEER
}

enum InternshipStatus {
  DECLARED
  ADMIN_PENDING
  ADMIN_VALIDATED
  SUPERVISOR_ASSIGNED
  SUBJECT_PENDING
  SUBJECT_VALIDATED
  IN_PROGRESS
  REPORT_LATE
  REPORT_WRITING
  READY_FOR_DEFENSE
  DEFENSE_AUTHORIZED
  DEFENSE_NOT_AUTHORIZED
  CLOSED
}

enum AdministrativeStatus {
  COMPLETE
  INCOMPLETE
  PENDING_DOCUMENTS
  REJECTED
}

enum MeetingType {
  PRESENTIAL
  REMOTE
}

enum SubjectDecision {
  ACCEPTED
  ACCEPTED_WITH_REFORMULATION
  NEEDS_CORRECTION
  REJECTED
}

enum WeeklyReportStatus {
  SUBMITTED_ON_TIME
  SUBMITTED_LATE
  MISSING
}

enum PfeDocumentCategory {
  INITIAL
  CORRECTED
  FINAL
  PRESENTATION
}

enum PfeDocumentValidationStatus {
  PENDING
  VALIDATED
  NEEDS_CORRECTION
  REJECTED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum InternshipDocumentType {
  CONVENTION
  ATTESTATION
  OTHER
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users User[]
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String
  mustChangePassword Boolean @default(true)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  student           Student?
  supervisor        Supervisor?
  internshipManager InternshipManager?
  departmentHead    DepartmentHead?
  admin             Admin?

  notifications Notification[]
  internshipDocumentsUploaded InternshipDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id   Int    @id @default(autoincrement())
  name String @unique

  students        Student[]
  supervisors     Supervisor[]
  departmentHeads DepartmentHead[]
}

model Student {
  id          Int    @id @default(autoincrement())
  studentCode String @unique

  level Level

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  internships Internship[]
}

model Supervisor {
  id Int @id @default(autoincrement())

  speciality String?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  internships Internship[]
}

model InternshipManager {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model DepartmentHead {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
}

model Admin {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Company {
  id   Int    @id @default(autoincrement())
  name String

  address String?
  email   String?
  phone   String?

  internships Internship[]
}

model Internship {
  id Int @id @default(autoincrement())

  title       String
  description String?

  startDate DateTime
  endDate   DateTime

  professionalSupervisor String?

  status InternshipStatus

  administrativeStatus AdministrativeStatus?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  companyId Int
  companyName String?
  company   Company @relation(fields: [companyId], references: [id])

  supervisorId Int?
  supervisor   Supervisor? @relation(fields: [supervisorId], references: [id])

  weeklyReports WeeklyReport[]
  meetings      Meeting[]
  documents     Document[]
  internshipDocuments InternshipDocument[]
  complaints    Complaint[]

  finalDecision      FinalDecision?
  subjectValidations SubjectValidation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id Int @id @default(autoincrement())

  completedWork String
  difficulties  String?
  nextWeekPlan  String?

  progress Int

  weekStartDate DateTime @db.Date
  status        WeeklyReportStatus

  supervisorComment String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id])

  attachments ReportAttachment[]

  @@unique([internshipId, weekStartDate])
}

model ReportAttachment {
  id Int @id @default(autoincrement())

  name String
  path String
  type String

  weeklyReportId Int
  weeklyReport   WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())
}

model Meeting {
  id Int @id @default(autoincrement())

  date DateTime

  type MeetingType

  summary           String?
  discussedPoints   String?
  decisions         String?
  assignedWork      String?
  supervisorComment String?

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id])
}

model Document {
  id Int @id @default(autoincrement())

  name String
  path String
  type String

  category         PfeDocumentCategory?
  validationStatus PfeDocumentValidationStatus @default(PENDING)
  supervisorComment String?

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id])

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([internshipId, category])
}

model InternshipDocument {
  id Int @id @default(autoincrement())

  type    InternshipDocumentType
  fileUrl String

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  uploadedById Int?
  uploadedBy   User? @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
}

model Complaint {
  id Int @id @default(autoincrement())

  subject     String
  description String

  status ComplaintStatus @default(PENDING)

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id])

  createdAt DateTime @default(now())
}

model FinalDecision {
  id Int @id @default(autoincrement())

  decision String
  comment  String?

  internshipId Int        @unique
  internship   Internship @relation(fields: [internshipId], references: [id])

  createdAt DateTime @default(now())
}

model SubjectValidation {
  id Int @id @default(autoincrement())

  decision          SubjectDecision
  comment           String?
  reformulatedTitle String?

  internshipId Int
  internship   Internship @relation(fields: [internshipId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id Int @id @default(autoincrement())

  title   String
  message String

  isRead Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
